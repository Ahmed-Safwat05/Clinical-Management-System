@model ProductEditViewModel
@{
    ViewData["Title"] = "تعديل منتج";
}

<div class="module-header">
    <div>
        <span class="module-kicker">المخزون</span>
        <h1>تعديل المنتج</h1>
        <p>تعديل بيانات المنتج الأساسية فقط. تعديل الكمية يتم من خلال حركات المخزون.</p>
    </div>
</div>

<div class="content-card">
    <form asp-action="Edit" method="post" class="form-layout">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-group">
            <label asp-for="Name" class="form-label">اسم المنتج <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="أدخل اسم المنتج" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Unit" class="form-label">وحدة القياس</label>
                <input asp-for="Unit" class="form-control" placeholder="مثال: كيس، زجاجة، علبة" />
                <span asp-validation-for="Unit" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="CostPrice" class="form-label">تكلفة الوحدة <span class="text-danger">*</span></label>
                <input asp-for="CostPrice" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                <span asp-validation-for="CostPrice" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="MinimumQuantity" class="form-label">الحد الأدنى للمخزون <span class="text-danger">*</span></label>
                <input asp-for="MinimumQuantity" type="number" min="0" class="form-control" placeholder="0" />
                <span asp-validation-for="MinimumQuantity" class="text-danger small"></span>
                <small class="form-text text-muted">عند الوصول لهذه الكمية، سيظهر تحذير في لوحة المخزون.</small>
            </div>

            <div class="form-group">
                <div class="form-check mt-4">
                    <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">تفعيل المنتج</label>
                </div>
            </div>
        </div>

        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i>
            لا يمكن تعديل كمية المخزون من هذه الصفحة. استخدم إضافة مخزون أو سحب مخزون من صفحة تفاصيل المنتج.
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i>
                حفظ التغييرات
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
