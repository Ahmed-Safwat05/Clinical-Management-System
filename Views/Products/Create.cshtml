@model Product
@{
    ViewData["Title"] = "إضافة منتج جديد";
}

<div class="module-header">
    <div>
        <span class="module-kicker">المخزون</span>
        <h1>إضافة منتج جديد</h1>
    </div>
</div>

<div class="content-card">
    <form asp-action="Create" method="post" class="form-layout">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-group">
            <label asp-for="Name" class="form-label">اسم المنتج <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="أدخل اسم المنتج" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Unit" class="form-label">وحدة القياس</label>
                <input asp-for="Unit" class="form-control" placeholder="مثال: كيس، زجاجة، علبة" />
                <span asp-validation-for="Unit" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="QuantityInStock" class="form-label">الكمية المتاحة <span class="text-danger">*</span></label>
                <input asp-for="QuantityInStock" type="number" min="0" class="form-control" placeholder="0" />
                <span asp-validation-for="QuantityInStock" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="CostPrice" class="form-label">السعر <span class="text-danger">*</span></label>
                <input asp-for="CostPrice" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                <span asp-validation-for="CostPrice" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="MinimumQuantity" class="form-label">الحد الأدنى للمخزون <span class="text-danger">*</span></label>
                <input asp-for="MinimumQuantity" type="number" min="0" class="form-control" placeholder="0" />
                <span asp-validation-for="MinimumQuantity" class="text-danger small"></span>
                <small class="form-text text-muted">عند الوصول لهذه الكمية، سيظهر تحذير</small>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i>
                حفظ المنتج
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
