@model PatientMedicalHistoryEntryFormViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
<input type="hidden" asp-for="Id" />
<input type="hidden" asp-for="PatientId" />

<div class="row g-3">
    <div class="col-12">
        <label asp-for="Title" class="form-label">عنوان السجل المرضي</label>
        <input asp-for="Title" class="form-control" placeholder="مثال: حساسية من البنسلين" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label">الوصف</label>
        <textarea asp-for="Description" class="form-control" rows="6" placeholder="اكتب التفاصيل الطبية المهمة باختصار ووضوح"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
</div>
