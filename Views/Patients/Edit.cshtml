@model Patient
@{
    ViewData["Title"] = "تعديل مريض";
}

<div class="module-header">
    <div>
        <span class="module-kicker">إدارة المرضى</span>
        <h1>تعديل بيانات المريض</h1>
        <p>حدّث بيانات التواصل والمعلومات الأساسية.</p>
    </div>
</div>
<div class="content-card form-card">
    <form asp-action="Edit" method="post" data-success-message="تم تحديث بيانات المريض">
        <input type="hidden" asp-for="Id" />
        <partial name="_PatientForm" model="Model" />
        <div class="form-actions">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2-circle"></i> حفظ التعديلات</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
