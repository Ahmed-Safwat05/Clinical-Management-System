@model PatientDetailsViewModel
@{
    ViewData["Title"] = "تفاصيل المريض";
}

<style>
    .patient-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .patient-info-card {
        padding: 16px;
        border: 1px solid var(--bs-border-color);
        border-radius: 12px;
        background-color: var(--bs-secondary-bg);
    }

    .patient-info-label {
        font-size: 0.875rem;
        color: var(--bs-secondary-color);
        margin-bottom: 4px;
        font-weight: 500;
    }

    .patient-info-value {
        font-size: 1rem;
        color: var(--bs-body-color);
        font-weight: 600;
    }

    .summary-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        padding: 16px;
        border: 1px solid var(--bs-border-color);
        border-radius: 12px;
        /* التخلص من الـ gradient الأبيض اللي كان مسبب المشكلة */
        background-color: var(--bs-tertiary-bg);
        margin-bottom: 24px;
    }

    .summary-stat {
        text-align: center;
        padding: 12px;
    }

    .summary-stat-label {
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        margin-bottom: 4px;
        font-weight: 500;
    }

    .summary-stat-value {
        font-size: 1.5rem;
        color: var(--bs-primary);
        font-weight: 700;
    }

    .timeline-container {
        display: grid;
        gap: 16px;
    }

    .timeline-item {
        padding: 16px;
        border: 1px solid var(--bs-border-color);
        border-radius: 12px;
        /* تغيير الخلفية البيضاء إلى ديناميكية */
        background-color: var(--bs-secondary-bg);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        align-items: start;
        transition: background-color 0.2s ease;
    }

        .timeline-item:hover {
            background-color: var(--bs-tertiary-bg);
        }

    .timeline-marker {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--bs-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

        .timeline-marker.voided {
            background: var(--bs-danger);
        }

    .timeline-content {
        display: grid;
        gap: 8px;
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 8px;
    }

    .timeline-date {
        font-size: 0.875rem;
        color: var(--bs-secondary-color);
    }

    .timeline-doctor {
        font-weight: 600;
        color: var(--bs-body-color);
    }

    .timeline-price {
        display: flex;
        gap: 12px;
        font-size: 0.875rem;
        color: var(--bs-body-color);
    }

    .timeline-price-item {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .timeline-notes {
        padding: 8px 12px;
        background: var(--bs-tertiary-bg);
        border-radius: 8px;
        font-size: 0.875rem;
        color: var(--bs-body-color);
        /* دعم الاتجاهين RTL و LTR تلقائياً */
        border-inline-start: 3px solid var(--bs-primary);
    }

    .status-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

        .status-badge.active {
            background-color: var(--bs-success-subtle);
            color: var(--bs-success-text-emphasis);
        }

        .status-badge.voided {
            background-color: var(--bs-danger-subtle);
            color: var(--bs-danger-text-emphasis);
        }

        .status-badge.partial {
            background-color: var(--bs-warning-subtle);
            color: var(--bs-warning-text-emphasis);
        }

        .status-badge.paid {
            background-color: var(--bs-info-subtle);
            color: var(--bs-info-text-emphasis);
        }

    .empty-state {
        text-align: center;
        padding: 32px 16px;
        color: var(--bs-secondary-color);
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 12px;
        opacity: 0.5;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .patient-name-header {
        font-size: 2rem;
        font-weight: 700;
        color: var(--bs-body-color);
    }
</style>

<div class="page-header">
    <div>
        <div class="text-secondary mb-2">إدارة المرضى</div>
        <div class="patient-name-header">@Model?.Patient?.Name</div>
    </div>
    <div class="action-buttons">
        <a asp-action="Edit" asp-route-id="@Model?.Patient?.Id" class="btn btn-outline-primary">
            <i class="bi bi-pencil"></i> تعديل
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> رجوع
        </a>
    </div>
</div>

<div class="card bg-body-tertiary border-secondary-subtle" style="margin-bottom: 24px; border-radius:16px; padding:20px;">
    <h5 class="mb-3 text-body"><i class="bi bi-person-badge"></i> المعلومات الأساسية</h5>
    <div class="patient-info-grid">
        <div class="patient-info-card">
            <div class="patient-info-label">الهاتف</div>
            <div class="patient-info-value">@Model?.Patient?.Phone</div>
        </div>
        <div class="patient-info-card">
            <div class="patient-info-label">العمر</div>
            <div class="patient-info-value">@Model?.Patient?.Age سنة</div>
        </div>
        <div class="patient-info-card">
            <div class="patient-info-label">النوع</div>
            <div class="patient-info-value">
                @if (Model?.Patient?.Gender == Gender.Male)
                {
                    <span>ذكر</span>
                }
                else
                {
                    <span>أنثى</span>
                }
            </div>
        </div>
    </div>
</div>

@if (Model?.HistorySummary?.HasHistory ?? false)
{
    <div class="card bg-body-tertiary border-secondary-subtle" style="margin-bottom: 24px; border-radius:16px; padding:20px;">
        <h5 class="mb-3 text-body"><i class="bi bi-graph-up"></i> ملخص السجل الطبي</h5>
        <div class="summary-section">
            <div class="summary-stat">
                <div class="summary-stat-label">إجمالي الزيارات</div>
                <div class="summary-stat-value">@Model.HistorySummary.TotalVisits</div>
            </div>
            <div class="summary-stat">
                <div class="summary-stat-label">آخر زيارة</div>
                <div class="summary-stat-value" style="font-size: 1.2rem; line-height: 2;">@Model.HistorySummary.LastVisitDate?.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="summary-stat">
                <div class="summary-stat-label">آخر طبيب</div>
                <div class="summary-stat-value" style="font-size: 1.1rem; line-height: 2.2;">@Model.HistorySummary.LastDoctorName</div>
            </div>
            <div class="summary-stat">
                <div class="summary-stat-label">إجمالي المبلغ</div>
                <div class="summary-stat-value">@Model.HistorySummary.TotalAmountSpent.ToString("0.##") ج.م</div>
            </div>
            <div class="summary-stat">
                <div class="summary-stat-label">المدفوع</div>
                <div class="summary-stat-value">@Model.HistorySummary.TotalAmountPaid.ToString("0.##") ج.م</div>
            </div>
        </div>
    </div>
}

<div class="card bg-body-tertiary border-secondary-subtle" style="border-radius:16px; padding:20px;">
    <h5 class="mb-3 text-body"><i class="bi bi-clock-history"></i> السجل الطبي الكامل</h5>

    @if (Model?.VisitTimeline?.Visits?.Any() ?? false)
    {
        <div class="timeline-container">
            @foreach (var visit in Model.VisitTimeline.Visits)
            {
                <a href="@Url.Action("Details", "Visits", new { id = visit.Id })" style="text-decoration: none;">
                    <div class="timeline-item">
                        <div class="timeline-marker @(visit.IsVoided ? "voided" : "")">
                            <i class="bi @(visit.IsVoided ? "bi-x-circle" : "bi-calendar-check")"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <div>
                                    <div class="timeline-date">
                                        @visit.Date.ToString("dddd، dd MMMM yyyy", new System.Globalization.CultureInfo("ar-SA"))
                                    </div>
                                    <div class="timeline-doctor">@visit.DoctorName</div>
                                </div>
                                <span class="status-badge @(visit.IsVoided ? "voided" : (visit.IsPaidInFull ? "paid" : "partial"))">
                                    @if (visit.IsVoided)
                                    {
                                        <span>ملغاة</span>
                                    }
                                    else if (visit.IsPaidInFull)
                                    {
                                        <span>مدفوعة</span>
                                    }
                                    else
                                    {
                                        <span>جزئية</span>
                                    }
                                </span>
                            </div>

                            <div class="timeline-price">
                                <div class="timeline-price-item">
                                    <span>السعر:</span>
                                    <strong class="text-primary">@visit.TotalPrice.ToString("0.##") ج.م</strong>
                                </div>
                                <div class="timeline-price-item">
                                    <span>المدفوع:</span>
                                    <strong class="text-success">@visit.TotalPaid.ToString("0.##") ج.م</strong>
                                </div>
                                @if (!visit.IsPaidInFull)
                                {
                                    <div class="timeline-price-item">
                                        <span>المتبقي:</span>
                                        <strong class="text-danger">@visit.RemainingBalance.ToString("0.##") ج.م</strong>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(visit.Notes))
                            {
                                <div class="timeline-notes">
                                    <strong>الملاحظات:</strong> @visit.Notes
                                </div>
                            }

                            @if (visit.IsVoided && !string.IsNullOrEmpty(visit.VoidReason))
                            {
                                <div style="padding: 8px 12px; background-color: var(--bs-danger-subtle); border-radius: 8px; font-size: 0.875rem; color: var(--bs-danger-text-emphasis); border-inline-start: 3px solid var(--bs-danger);">
                                    <strong>سبب الإلغاء:</strong> @visit.VoidReason
                                </div>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-inbox"></i>
            </div>
            <p>لا توجد زيارات للمريض حتى الآن</p>
        </div>
    }
</div>