@model Patient

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Name" class="form-label">اسم المريض</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Phone" class="form-label">رقم الهاتف</label>
        <input asp-for="Phone" class="form-control" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Age" class="form-label">العمر</label>
        <input asp-for="Age" class="form-control" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Gender" class="form-label">النوع</label>
        <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select"></select>
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>
</div>
