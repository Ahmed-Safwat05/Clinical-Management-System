@model Procedure
@{
    ViewData["Title"] = "إضافة إجراء";
}

<div class="module-header">
    <div>
        <span class="module-kicker">إدارة الخدمات الطبية</span>
        <h1>إضافة إجراء</h1>
        <p>حدد اسم الإجراء والسعر الافتراضي.</p>
    </div>
</div>
<div class="content-card form-card">
    <form asp-action="Create" method="post" data-success-message="تم حفظ الإجراء بنجاح">
        <partial name="_ProcedureForm" model="Model" />
        <div class="form-actions">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2-circle"></i> حفظ</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
