@model Doctor
@{
    ViewData["Title"] = "إضافة طبيب";
}

<div class="module-header">
    <div>
        <span class="module-kicker">إدارة الفريق الطبي</span>
        <h1>إضافة طبيب</h1>
        <p>أضف بيانات الطبيب وتخصصه الأساسي.</p>
    </div>
</div>
<div class="content-card form-card">
    <form asp-action="Create" method="post" data-success-message="تم حفظ الطبيب بنجاح">
        <partial name="_DoctorForm" model="Model" />
        <div class="form-actions">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2-circle"></i> حفظ</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
