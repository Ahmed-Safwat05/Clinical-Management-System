@model ClinicManagementSystem.Models.ViewModels.DashboardAnalyticsViewModel
@{
    ViewData["Title"] = "لوحة التحليلات";
    var monthlyLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueChart.Select(x => x.Label));
    var monthlyRevenueJson = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueChart.Select(x => x.Revenue));
    var yearlyLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.YearlyRevenueChart.Select(x => x.Label));
    var yearlyRevenueJson = System.Text.Json.JsonSerializer.Serialize(Model.YearlyRevenueChart.Select(x => x.Revenue));
}

<!-- Header & Filter Section -->
<section class="dashboard-hero d-flex flex-wrap justify-content-between align-items-center mb-4" style="overflow: visible;">
    <div>
        <span class="eyebrow">تحليلات تفصيلية</span>
        <h1>لوحة مؤشرات العيادة</h1>
        <p>متابعة دقيقة للفواتير، المدفوعات، الأرصدة المستحقة، الزيارات، والمخزون.</p>
    </div>
    <div class="d-flex align-items-center gap-3" style="overflow: visible;">
        <form method="get" asp-action="Index" class="m-0">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white text-primary border-primary">
                    <i class="bi bi-calendar-month"></i>
                </span>
                <input type="month" id="selectedMonthInput" name="selectedDate" class="form-control border-primary fw-bold text-secondary"
                       value="@ViewData["SelectedMonth"]"
                       onchange="this.form.submit()"
                       style="cursor: pointer; max-width: 180px;" />
            </div>
        </form>

        <!-- الـ Dropdown مكانه هنا بعد الفلتر وقبل زرار الرئيسية عشان التنسيق يظبط تمام -->
        <div class="dropdown shadow-sm" style="z-index: 1050;">
            <button type="button" class="btn btn-outline-danger fw-bold dropdown-toggle" id="dropdownReportsBtn" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false">
                <i class="bi bi-file-earmark-pdf-fill"></i> طباعة التقرير
            </button>
            <ul class="dropdown-menu dropdown-menu-start shadow-lg m-0" aria-labelledby="dropdownReportsBtn" style="min-width: 220px; text-align: right;">
                <li class="p-2 border-bottom bg-light">
                    <span class="text-dark fw-bold" style="font-size: 0.85rem;">
                        <i class="bi bi-gear-fill text-secondary ms-1"></i> اختر نوع التقرير
                    </span>
                </li>
                <li>
                    <a class="dropdown-item fw-bold py-2" asp-controller="Dashboard" asp-action="DownloadRevenueReport" asp-route-reportType="Daily" asp-route-fromDate="@DateTime.Today.ToString("yyyy-MM-dd")">
                        <i class="bi bi-calendar-event text-danger ms-2"></i> تقرير الخزنة اليومي
                    </a>
                </li>
                <li>
                    <button type="button" class="dropdown-item fw-bold py-2 w-100 text-end" onclick="downloadCurrentMonthReport()">
                        <i class="bi bi-calendar-range text-danger ms-2"></i> تقرير الشهر المختار
                    </button>
                </li>
            </ul>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary hero-action shadow-sm">
            <i class="bi bi-speedometer2"></i>
            الرجوع للرئيسية
        </a>
    </div>
</section>
<section class="stats-grid mb-4">
    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-blue"><i class="bi bi-receipt"></i></div>
        <div>
            <span>إجمالي الفواتير</span>
            <div class="d-flex align-items-baseline gap-1">
                <strong>@Model.MonthFinancials.BilledRevenue.ToString("N0")</strong>
                <small class="text-muted fw-bold">ج.م</small>
            </div>
            <small class="growth neutral d-block">الشهر الحالي</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-green"><i class="bi bi-cash-coin"></i></div>
        <div>
            <span>إجمالي المحصل</span>
            <div class="d-flex align-items-baseline gap-1">
                <strong>@Model.MonthFinancials.CollectedRevenue.ToString("N0")</strong>
                <small class="text-muted fw-bold">ج.م</small>
            </div>
            <small class="growth @(Model.RevenueTrendPercentage >= 0 ? "positive" : "neutral") d-block">
                @Model.RevenueTrendPercentage.ToString("N1")% مقارنة بالسابق
            </small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-amber"><i class="bi bi-exclamation-circle"></i></div>
        <div>
            <span>الرصيد المستحق</span>
            <div class="d-flex align-items-baseline gap-1">
                <strong>@Model.MonthFinancials.OutstandingBalance.ToString("N0")</strong>
                <small class="text-muted fw-bold">ج.م</small>
            </div>
            <small class="growth neutral d-block">فواتير غير محصلة</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-purple"><i class="bi bi-award-fill"></i></div>
        <div>
            <span>أفضل طبيب</span>
            <strong style="font-size: 1.2rem; display: block;">@(Model.TopDoctorName ?? "-")</strong>
            <small class="growth neutral d-block">@Model.TopDoctorVisitsCount زيارة هذا الشهر</small>
        </div>
    </article>
</section>

<section class="content-card mb-4">
    <div class="section-head">
        <div>
            <h2>ملخص مالي حسب الفترة</h2>
            <p>الفواتير من إجمالي الزيارات، والتحصيل من سجلات المدفوعات الفعلية.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>الفترة</th>
                    <th>إجمالي الفواتير</th>
                    <th>إجمالي المحصل</th>
                    <th>الرصيد المستحق</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>اليوم</td>
                    <td>@Model.TodayFinancials.BilledRevenue.ToString("0.##") ج.م</td>
                    <td class="text-success fw-bold">@Model.TodayFinancials.CollectedRevenue.ToString("0.##") ج.م</td>
                    <td class="text-warning fw-bold">@Model.TodayFinancials.OutstandingBalance.ToString("0.##") ج.م</td>
                </tr>
                <tr>
                    <td>الشهر الحالي</td>
                    <td>@Model.MonthFinancials.BilledRevenue.ToString("0.##") ج.م</td>
                    <td class="text-success fw-bold">@Model.MonthFinancials.CollectedRevenue.ToString("0.##") ج.م</td>
                    <td class="text-warning fw-bold">@Model.MonthFinancials.OutstandingBalance.ToString("0.##") ج.م</td>
                </tr>
                <tr>
                    <td>السنة الحالية</td>
                    <td>@Model.YearFinancials.BilledRevenue.ToString("0.##") ج.م</td>
                    <td class="text-success fw-bold">@Model.YearFinancials.CollectedRevenue.ToString("0.##") ج.م</td>
                    <td class="text-warning fw-bold">@Model.YearFinancials.OutstandingBalance.ToString("0.##") ج.م</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="stats-grid mb-4">
    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-green"><i class="bi bi-check-circle-fill"></i></div>
        <div>
            <span>زيارات مدفوعة بالكامل</span>
            <strong>@Model.PaymentStatus.FullyPaidVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">عدد الزيارات</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-amber"><i class="bi bi-pie-chart-fill"></i></div>
        <div>
            <span>زيارات مدفوعة جزئيا</span>
            <strong>@Model.PaymentStatus.PartiallyPaidVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">عدد الزيارات</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-purple"><i class="bi bi-wallet2"></i></div>
        <div>
            <span>زيارات غير مدفوعة</span>
            <strong>@Model.PaymentStatus.UnpaidVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">عدد الزيارات</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-blue"><i class="bi bi-clipboard2-pulse-fill"></i></div>
        <div>
            <span>زيارات الشهر</span>
            <strong>@Model.MonthlyVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">@Model.YearlyVisitsCount.ToString("N0") زيارة خلال السنة</small>
        </div>
    </article>
</section>

<section class="row mb-4">
    <div class="col-lg-6 mb-4 mb-lg-0">
        <div class="dashboard-card chart-panel h-100 p-4">
            <div class="section-head mb-4">
                <div>
                    <h2>المحصل اليومي خلال الشهر</h2>
                    <p class="text-muted small mb-0">يعتمد الرسم على سجلات المدفوعات الفعلية فقط.</p>
                </div>
            </div>
            <div style="position: relative; height: 300px; width: 100%;">
                <canvas id="monthlyAnalyticsChart" data-labels='@monthlyLabelsJson' data-revenue='@monthlyRevenueJson'></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="dashboard-card chart-panel h-100 p-4">
            <div class="section-head mb-4">
                <div>
                    <h2>المحصل الشهري خلال السنة</h2>
                    <p class="text-muted small mb-0">مقارنة شهرية لقيم التحصيل المسجلة في المدفوعات.</p>
                </div>
            </div>
            <div style="position: relative; height: 300px; width: 100%;">
                <canvas id="yearlyAnalyticsChart" data-labels='@yearlyLabelsJson' data-revenue='@yearlyRevenueJson'></canvas>
            </div>
        </div>
    </div>
</section>

<section class="row">
    <div class="col-lg-7 mb-4">
        <div class="content-card h-100">
            <div class="section-head">
                <div>
                    <h2>أعلى المرضى مديونية</h2>
                    <p>أعلى 5 مرضى حسب الرصيد المستحق.</p>
                </div>
            </div>
            @if (Model.TopDebtors.Any())
            {
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>المريض</th>
                                <th>الرصيد المستحق</th>
                                <th class="text-end">الإجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var debtor in Model.TopDebtors)
                            {
                                <tr>
                                    <td>@debtor.PatientName</td>
                                    <td class="text-warning fw-bold">@debtor.OutstandingBalance.ToString("0.##") ج.م</td>
                                    <td class="text-end">
                                        <a asp-controller="Patients" asp-action="History" asp-route-id="@debtor.PatientId" class="btn btn-sm btn-soft">
                                            <i class="bi bi-person-lines-fill"></i> الملف
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-success m-3">
                    <i class="bi bi-check-circle-fill"></i> لا توجد أرصدة مستحقة حاليا.
                </div>
            }
        </div>
    </div>

    <div class="col-lg-5 mb-4">
        <div class="content-card h-100">
            <div class="section-head">
                <div>
                    <h2>ملخص التحليل</h2>
                    <p>أرقام مجمعة من سجلات الزيارات والمدفوعات.</p>
                </div>
            </div>
            <div class="details-grid">
                <div class="detail-tile"><span>زيارات السنة</span><strong>@Model.YearlyVisitsCount.ToString("N0")</strong></div>
                <div class="detail-tile"><span>محصل الشهر السابق</span><strong>@Model.PreviousMonthRevenue.ToString("0.##") ج.م</strong></div>
                <div class="detail-tile"><span>محصل الشهر الحالي</span><strong>@Model.MonthlyRevenue.ToString("0.##") ج.م</strong></div>
                <div class="detail-tile"><span>الاتجاه</span><strong class="@(Model.RevenueTrendPercentage >= 0 ? "text-success" : "text-danger")">@Model.RevenueTrendPercentage.ToString("0.##")%</strong></div>
            </div>
        </div>
    </div>
</section>

<section class="row">
    <div class="col-lg-6 mb-4">
        <div class="content-card h-100">
            <div class="section-head">
                <div>
                    <h2>منتجات قاربت على النفاد</h2>
                    <p>المنتجات التي وصلت الحد الأدنى من المخزون.</p>
                </div>
                <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-primary">عرض المخزون</a>
            </div>
            @if (Model.LowStockProducts.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>اسم المنتج</th>
                                <th class="text-center">الكمية الحالية</th>
                                <th class="text-center">الحد الأدنى</th>
                                <th class="text-center">الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.LowStockProducts)
                            {
                                <tr>
                                    <td><strong>@product.Name</strong></td>
                                    <td class="text-center"><span class="badge bg-danger">@product.QuantityInStock</span></td>
                                    <td class="text-center">@product.MinimumQuantity</td>
                                    <td class="text-center">
                                        @if (product.QuantityInStock == 0)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill"></i> نفاد تام</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning"><i class="bi bi-exclamation-circle-fill"></i> تحذير</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-success m-3">
                    <i class="bi bi-check-circle-fill"></i> جميع المنتجات بحالة جيدة.
                </div>
            }
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="content-card h-100">
            <div class="section-head">
                <div>
                    <h2>الأكثر استهلاكا هذا الشهر</h2>
                    <p>أكثر 5 منتجات استخداما خلال الشهر الحالي.</p>
                </div>
            </div>
            @if (Model.MostConsumedProducts.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>اسم المنتج</th>
                                <th class="text-center">إجمالي المستهلك</th>
                                <th class="text-center">الاستخدامات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.MostConsumedProducts.Count; i++)
                            {
                                var product = Model.MostConsumedProducts[i];
                                <tr>
                                    <td><span class="badge bg-primary">@(i + 1)</span></td>
                                    <td><strong>@product.ProductName</strong></td>
                                    <td class="text-center"><span class="badge bg-info">@product.TotalQuantityConsumed</span></td>
                                    <td class="text-center">@product.ConsumptionCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info m-3">
                    <i class="bi bi-info-circle-fill"></i> لا توجد بيانات استهلاك متاحة لهذا الشهر.
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function downloadCurrentMonthReport() {
            const monthVal = document.getElementById('selectedMonthInput').value;
            if (monthVal) {
                const fromDate = monthVal + "-01";
                window.location.href = `/Dashboard/DownloadRevenueReport?reportType=Monthly&fromDate=${fromDate}`;
            } else {
                window.location.href = `/Dashboard/DownloadRevenueReport?reportType=Monthly`;
            }
        }
    </script>
}