@model DashboardAnalyticsViewModel
@{
    ViewData["Title"] = "لوحة التحليلات";
    var monthlyLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueChart.Select(x => x.Label));
    var monthlyRevenueJson = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueChart.Select(x => x.Revenue));
    var yearlyLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.YearlyRevenueChart.Select(x => x.Label));
    var yearlyRevenueJson = System.Text.Json.JsonSerializer.Serialize(Model.YearlyRevenueChart.Select(x => x.Revenue));
}

<section class="dashboard-hero">
    <div>
        <span class="eyebrow">تحليلات تفصيلية</span>
        <h1>لوحة مؤشرات العيادة</h1>
        <p>متابعة دقيقة للفواتير، المدفوعات، الأرصدة المستحقة، الزيارات، والمخزون.</p>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary hero-action">
        <i class="bi bi-speedometer2"></i>
        الرجوع للرئيسية
    </a>
</section>

<section class="stats-grid">
    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-blue"><i class="bi bi-receipt"></i></div>
        <div>
            <span>إجمالي الفواتير</span>
            <strong>@Model.MonthFinancials.BilledRevenue.ToString("C")</strong>
            <small class="growth neutral">الشهر الحالي</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-green"><i class="bi bi-cash-coin"></i></div>
        <div>
            <span>إجمالي المحصل</span>
            <strong>@Model.MonthFinancials.CollectedRevenue.ToString("C")</strong>
            <small class="growth @(Model.RevenueTrendPercentage >= 0 ? "positive" : "neutral")">
                @Model.RevenueTrendPercentage.ToString("N2")% مقارنة بالشهر السابق
            </small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-amber"><i class="bi bi-exclamation-circle"></i></div>
        <div>
            <span>الرصيد المستحق</span>
            <strong>@Model.MonthFinancials.OutstandingBalance.ToString("C")</strong>
            <small class="growth neutral">فواتير الشهر غير المحصلة</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-purple"><i class="bi bi-award-fill"></i></div>
        <div>
            <span>أفضل طبيب هذا الشهر</span>
            <strong>@(Model.TopDoctorName ?? "-")</strong>
            <small class="growth neutral">@Model.TopDoctorVisitsCount زيارات</small>
        </div>
    </article>
</section>

<section class="content-card">
    <div class="section-head">
        <div>
            <h2>ملخص مالي حسب الفترة</h2>
            <p>الفواتير من إجمالي الزيارات، والتحصيل من سجلات المدفوعات الفعلية.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>الفترة</th>
                    <th>إجمالي الفواتير</th>
                    <th>إجمالي المحصل</th>
                    <th>الرصيد المستحق</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>اليوم</td>
                    <td>@Model.TodayFinancials.BilledRevenue.ToString("N2") ج.م</td>
                    <td class="text-success fw-bold">@Model.TodayFinancials.CollectedRevenue.ToString("N2") ج.م</td>
                    <td class="text-warning fw-bold">@Model.TodayFinancials.OutstandingBalance.ToString("N2") ج.م</td>
                </tr>
                <tr>
                    <td>الشهر الحالي</td>
                    <td>@Model.MonthFinancials.BilledRevenue.ToString("N2") ج.م</td>
                    <td class="text-success fw-bold">@Model.MonthFinancials.CollectedRevenue.ToString("N2") ج.م</td>
                    <td class="text-warning fw-bold">@Model.MonthFinancials.OutstandingBalance.ToString("N2") ج.م</td>
                </tr>
                <tr>
                    <td>السنة الحالية</td>
                    <td>@Model.YearFinancials.BilledRevenue.ToString("N2") ج.م</td>
                    <td class="text-success fw-bold">@Model.YearFinancials.CollectedRevenue.ToString("N2") ج.م</td>
                    <td class="text-warning fw-bold">@Model.YearFinancials.OutstandingBalance.ToString("N2") ج.م</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="stats-grid">
    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-green"><i class="bi bi-check-circle-fill"></i></div>
        <div>
            <span>زيارات مدفوعة بالكامل</span>
            <strong>@Model.PaymentStatus.FullyPaidVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">عدد الزيارات</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-amber"><i class="bi bi-pie-chart-fill"></i></div>
        <div>
            <span>زيارات مدفوعة جزئيا</span>
            <strong>@Model.PaymentStatus.PartiallyPaidVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">عدد الزيارات</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-purple"><i class="bi bi-wallet2"></i></div>
        <div>
            <span>زيارات غير مدفوعة</span>
            <strong>@Model.PaymentStatus.UnpaidVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">عدد الزيارات</small>
        </div>
    </article>

    <article class="dashboard-card stat-summary">
        <div class="stat-icon bg-blue"><i class="bi bi-clipboard2-pulse-fill"></i></div>
        <div>
            <span>زيارات الشهر</span>
            <strong>@Model.MonthlyVisitsCount.ToString("N0")</strong>
            <small class="growth neutral">@Model.YearlyVisitsCount.ToString("N0") زيارة خلال السنة</small>
        </div>
    </article>
</section>

<section class="dashboard-grid">
    <div class="dashboard-card chart-panel" style="height: 300px; width: 100%;">
        <div class="section-head">
            <div>
                <h2>المحصل اليومي خلال الشهر</h2>
                <p>يعتمد الرسم على سجلات المدفوعات الفعلية فقط.</p>
            </div>
        </div>
        <canvas id="monthlyAnalyticsChart"
                height="280"
                data-labels='@monthlyLabelsJson'
                data-revenue='@monthlyRevenueJson'></canvas>
    </div>

    <div class="dashboard-card chart-panel" style="height: 300px; width: 100%;">
        <div class="section-head">
            <div>
                <h2>المحصل الشهري خلال السنة</h2>
                <p>مقارنة شهرية لقيم التحصيل المسجلة في المدفوعات.</p>
            </div>
        </div>
        <canvas id="yearlyAnalyticsChart"
                height="280"
                data-labels='@yearlyLabelsJson'
                data-revenue='@yearlyRevenueJson'></canvas>
    </div>
</section>

<section class="dashboard-grid">
    <div class="content-card">
        <div class="section-head">
            <div>
                <h2>أعلى المرضى مديونية</h2>
                <p>أعلى 5 مرضى حسب الرصيد المستحق.</p>
            </div>
        </div>
        @if (Model.TopDebtors.Any())
        {
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>المريض</th>
                            <th>الرصيد المستحق</th>
                            <th class="text-end">الإجراء</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var debtor in Model.TopDebtors)
                    {
                        <tr>
                            <td>@debtor.PatientName</td>
                            <td class="text-warning fw-bold">@debtor.OutstandingBalance.ToString("N2") ج.م</td>
                            <td class="text-end">
                                <a asp-controller="Patients" asp-action="History" asp-route-id="@debtor.PatientId" class="btn btn-sm btn-soft">
                                    <i class="bi bi-person-lines-fill"></i>
                                    الملف
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-success mb-0">
                <i class="bi bi-check-circle-fill"></i>
                لا توجد أرصدة مستحقة حاليا.
            </div>
        }
    </div>

    <div class="content-card">
        <div class="section-head">
            <div>
                <h2>ملخص التحليل</h2>
                <p>أرقام مجمعة من سجلات الزيارات والمدفوعات.</p>
            </div>
        </div>
        <div class="details-grid">
            <div class="detail-tile"><span>زيارات السنة</span><strong>@Model.YearlyVisitsCount.ToString("N0")</strong></div>
            <div class="detail-tile"><span>محصل الشهر السابق</span><strong>@Model.PreviousMonthRevenue.ToString("C")</strong></div>
            <div class="detail-tile"><span>محصل الشهر الحالي</span><strong>@Model.MonthlyRevenue.ToString("C")</strong></div>
            <div class="detail-tile"><span>الاتجاه</span><strong>@Model.RevenueTrendPercentage.ToString("N2")%</strong></div>
        </div>
    </div>
</section>

<section class="content-card">
    <div class="section-head">
        <div>
            <h2>منتجات قاربت على النفاد</h2>
            <p>المنتجات التي وصلت الحد الأدنى من المخزون.</p>
        </div>
        <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-boxes"></i>
            عرض المخزون
        </a>
    </div>
    @if (Model.LowStockProducts.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>اسم المنتج</th>
                        <th class="text-center">الكمية الحالية</th>
                        <th class="text-center">الحد الأدنى</th>
                        <th class="text-center">الحالة</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var product in Model.LowStockProducts)
                {
                    <tr>
                        <td><strong>@product.Name</strong></td>
                        <td class="text-center"><span class="badge bg-danger">@product.QuantityInStock</span></td>
                        <td class="text-center">@product.MinimumQuantity</td>
                        <td class="text-center">
                            @if (product.QuantityInStock == 0)
                            {
                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill"></i> نفاد تام</span>
                            }
                            else
                            {
                                <span class="badge bg-warning"><i class="bi bi-exclamation-circle-fill"></i> تحذير</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            جميع المنتجات بحالة جيدة.
        </div>
    }
</section>

<section class="content-card">
    <div class="section-head">
        <div>
            <h2>الأكثر استهلاكا هذا الشهر</h2>
            <p>أكثر 5 منتجات استخداما خلال الشهر الحالي.</p>
        </div>
    </div>
    @if (Model.MostConsumedProducts.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>اسم المنتج</th>
                        <th class="text-center">إجمالي المستهلك</th>
                        <th class="text-center">عدد الاستخدامات</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.MostConsumedProducts.Count; i++)
                {
                    var product = Model.MostConsumedProducts[i];
                    <tr>
                        <td><span class="badge bg-primary">@(i + 1)</span></td>
                        <td><strong>@product.ProductName</strong></td>
                        <td class="text-center"><span class="badge bg-info">@product.TotalQuantityConsumed</span></td>
                        <td class="text-center">@product.ConsumptionCount</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle-fill"></i>
            لا توجد بيانات استهلاك متاحة لهذا الشهر.
        </div>
    }
</section>

<section class="content-card shadow-sm border-0">
    <div class="section-head mb-4">
        <div>
            <h2 class="fw-bold">ملخص الطابور اليوم</h2>
            <p class="text-muted">حالة المواعيد والحجوزات في يومك الحالي.</p>
        </div>
    </div>
    <div class="queue-summary-grid">
        <div class="queue-tile waiting">
            <div class="queue-icon"><i class="bi bi-clock-history"></i></div>
            <div class="queue-info">
                <span>عدد المنتظرين</span>
                <strong>@(Model.QueueSummary?.WaitingCount ?? 0)</strong>
            </div>
        </div>

        <div class="queue-tile completed">
            <div class="queue-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="queue-info">
                <span>عدد المكتمل</span>
                <strong>@(Model.QueueSummary?.CompletedCount ?? 0)</strong>
            </div>
        </div>

        <div class="queue-tile cancelled">
            <div class="queue-icon"><i class="bi bi-x-circle-fill"></i></div>
            <div class="queue-info">
                <span>عدد الملغي</span>
                <strong>@(Model.QueueSummary?.CancelledCount ?? 0)</strong>
            </div>
        </div>

        <div class="queue-tile walkin">
            <div class="queue-icon"><i class="bi bi-person-plus-fill"></i></div>
            <div class="queue-info">
                <span>الحجوزات السريعة</span>
                <strong>@(Model.QueueSummary?.WalkInCount ?? 0)</strong>
            </div>
        </div>
    </div>
</section>
