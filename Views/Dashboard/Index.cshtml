<!-- Widget 3: Today Queue Summary -->
<section class="content-card shadow-sm border-0">
    <div class="section-head mb-4">
        <div>
            <h2 class="fw-bold">ملخص الطابور اليوم</h2>
            <p class="text-muted">حالة المواعيد والحجوزات في يومك الحالي</p>
        </div>
    </div>
    <div class="queue-summary-grid">
        <!-- المنتظرين -->
        <div class="queue-tile waiting">
            <div class="queue-icon">
                <i class="bi bi-clock-history"></i>
            </div>
            <div class="queue-info">
                <span>عدد المنتظرين</span>
                <strong>@(Model.QueueSummary?.WaitingCount ?? 0)</strong>
            </div>
        </div>

        <!-- المكتمل -->
        <div class="queue-tile completed">
            <div class="queue-icon">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="queue-info">
                <span>عدد المكتمل</span>
                <strong>@(Model.QueueSummary?.CompletedCount ?? 0)</strong>
            </div>
        </div>

        <!-- الملغي -->
        <div class="queue-tile cancelled">
            <div class="queue-icon">
                <i class="bi bi-x-circle-fill"></i>
            </div>
            <div class="queue-info">
                <span>عدد الملغي</span>
                <strong>@(Model.QueueSummary?.CancelledCount ?? 0)</strong>
            </div>
        </div>

        <!-- الحجوزات السريعة -->
        <div class="queue-tile walkin">
            <div class="queue-icon">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <div class="queue-info">
                <span>الحجوزات السريعة</span>
                <strong>@(Model.QueueSummary?.WalkInCount ?? 0)</strong>
            </div>
        </div>
    </div>
</section>
