@model VisitDetailsViewModel
@{
    var visit = Model.Visit;
    ViewData["Title"] = "تفاصيل الزيارة";
}

<div class="module-header">
    <div>
        <span class="module-kicker">الاستشارات الطبية</span>
        <h1>تفاصيل الزيارة</h1>
        <p>ملخص الزيارة، الطبيب، المريض، الإجراءات، المدفوعات، والمنتجات المستهلكة.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right"></i>
        رجوع
    </a>
</div>

<div class="content-card mb-3">
    <div class="details-grid">
        <div class="detail-tile"><span>التاريخ</span><strong>@visit.Date.ToString("yyyy-MM-dd")</strong></div>
        <div class="detail-tile"><span>المريض</span><strong>@visit.Patient?.Name</strong></div>
        <div class="detail-tile"><span>الطبيب</span><strong>@visit.Doctor?.Name</strong></div>
        <div class="detail-tile">
            <span>الحالة</span>
            @if (visit.IsVoided)
            {
                <span class="status-badge danger mt-2">ملغاة</span>
            }
            else
            {
                <span class="status-badge success mt-2">نشطة</span>
            }
        </div>
        <div class="detail-tile"><span>الدفع</span><strong>@visit.TotalPaid.ToString("N2") ج.م / @visit.TotalPrice.ToString("N2") ج.م</strong></div>
    </div>
    @if (!string.IsNullOrWhiteSpace(visit.Notes))
    {
        <div class="notes-box">
            <strong>ملاحظات الطبيب</strong>
            <p class="mb-0">@visit.Notes</p>
        </div>
    }
    @if (visit.IsVoided && visit.VoidedAt.HasValue)
    {
        <div class="alert alert-warning" role="alert">
            <h5 class="alert-heading">الزيارة ملغاة</h5>
            <p class="mb-2"><strong>تاريخ الإلغاء:</strong> @visit.VoidedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
            @if (!string.IsNullOrWhiteSpace(visit.VoidReason))
            {
                <p class="mb-0"><strong>سبب الإلغاء:</strong> @visit.VoidReason</p>
            }
        </div>
    }
</div>

<div class="content-card mb-3">
    <div class="section-head">
        <h2>التفاصيل المالية</h2>
    </div>
    <div class="details-grid">
        <div class="detail-tile">
            <span>قيمة الكشف</span>
            <strong>@visit.ExaminationPrice.ToString("N2") ج.م</strong>
        </div>
        <div class="detail-tile">
            <span>إجمالي الإجراءات</span>
            <strong>@visit.ProceduresPrice.ToString("N2") ج.م</strong>
        </div>
        <div class="detail-tile">
            <span>الخصم</span>
            <strong class="text-danger">@visit.Discount.ToString("N2") ج.م</strong>
        </div>
        <div class="detail-tile">
            <span>الإجمالي النهائي</span>
            <strong class="text-primary">@visit.TotalPrice.ToString("N2") ج.م</strong>
        </div>
        <div class="detail-tile">
            <span>المبلغ المدفوع</span>
            <strong class="text-success">@visit.TotalPaid.ToString("N2") ج.م</strong>
        </div>
        <div class="detail-tile">
            <span>المتبقي</span>
            <strong class="@(visit.RemainingBalance > 0 ? "text-warning" : "text-success")">@visit.RemainingBalance.ToString("N2") ج.م</strong>
        </div>
        <div class="detail-tile">
            <span>حالة الدفع</span>
            <span class="status-badge @(visit.IsPaidInFull ? "confirmed" : "waiting") mt-2">
                @(visit.IsPaidInFull ? "مدفوع بالكامل" : "مستحق")
            </span>
        </div>
    </div>
</div>

<div class="content-card mb-3">
    <div class="section-head">
        <div>
            <h2>المدفوعات</h2>
            <p>سجل الدفعات المسجلة على هذه الزيارة.</p>
        </div>
        @if (visit.RemainingBalance > 0)
        {
            <a asp-action="AddPayment" asp-route-visitId="@visit.Id" class="btn btn-primary">
                <i class="bi bi-cash-coin"></i>
                إضافة دفعة
            </a>
        }
    </div>

    @if (visit.Payments.Any())
    {
        <div class="table-responsive">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>تاريخ الدفع</th>
                        <th>المبلغ</th>
                        <th>الملاحظات</th>
                        <th>المستخدم</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var payment in visit.Payments.OrderByDescending(x => x.CreatedAt))
                {
                    <tr>
                        <td>@payment.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="fw-bold text-success">@payment.Amount.ToString("N2") ج.م</td>
                        <td>@(string.IsNullOrWhiteSpace(payment.Notes) ? "-" : payment.Notes)</td>
                        <td>@(string.IsNullOrWhiteSpace(payment.CreatedBy) ? "-" : payment.CreatedBy)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state py-4">
            <i class="bi bi-cash-stack"></i>
            <h3>لا توجد دفعات مسجلة</h3>
            <p>يمكن إضافة دفعات جزئية حتى يتم سداد الزيارة بالكامل.</p>
        </div>
    }
</div>

<div class="content-card mb-3">
    <div class="section-head">
        <div>
            <h2>المنتجات المستهلكة</h2>
            <p>تسجيل وعرض المنتجات التي تم استهلاكها أثناء الزيارة.</p>
        </div>
        <span class="badge bg-light text-dark">إجمالي التكلفة: @Model.TotalConsumptionCost.ToString("N2") ج.م</span>
    </div>

    <form asp-action="ConsumeProduct" method="post" class="row g-2 align-items-end mb-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="visitId" value="@visit.Id" />

        <div class="col-lg-7">
            <label class="form-label" for="productId">المنتج</label>
            <select id="productId" name="productId" class="form-select" asp-items="Model.AvailableProducts" required>
                <option value="">اختر المنتج</option>
            </select>
        </div>

        <div class="col-lg-3">
            <label class="form-label" for="quantity">الكمية</label>
            <input id="quantity" name="quantity" type="number" min="1" value="1" class="form-control" required />
        </div>

        <div class="col-lg-2 d-grid">
            <button type="submit" class="btn btn-primary" @(Model.AvailableProducts.Any() ? null : "disabled")>
                <i class="bi bi-plus-circle"></i>
                إضافة استهلاك
            </button>
        </div>
    </form>

    @if (Model.ProductConsumptions.Any())
    {
        <div class="table-responsive">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>المنتج</th>
                        <th>الكمية</th>
                        <th>تكلفة الوحدة</th>
                        <th>إجمالي التكلفة</th>
                        <th>تاريخ الاستهلاك</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.ProductConsumptions.OrderByDescending(x => x.CreatedAt))
                {
                    var unitCost = item.Product?.CostPrice ?? 0m;
                    var totalCost = unitCost * item.QuantityConsumed;
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>@item.QuantityConsumed @(item.Product?.Unit ?? "")</td>
                        <td>@unitCost.ToString("N2") ج.م</td>
                        <td class="fw-bold">@totalCost.ToString("N2") ج.م</td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state py-4">
            <i class="bi bi-box-seam"></i>
            <h3>لا توجد منتجات مستهلكة</h3>
            <p>يمكن تسجيل استهلاك المنتجات الطبية المرتبطة بهذه الزيارة من النموذج أعلاه.</p>
        </div>
    }
</div>

<div class="content-card">
    <div class="section-head">
        <div>
            <h2>الإجراءات الطبية</h2>
            <p>الإجراءات المسجلة داخل الزيارة.</p>
        </div>
    </div>
    <table class="table admin-table mb-0">
        <thead>
            <tr>
                <th>الإجراء</th>
                <th>الكمية</th>
                <th>الإجمالي الفرعي</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in visit.VisitProcedures)
        {
            <tr>
                <td>@item.Procedure?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.SubTotal.ToString("N2") ج.م</td>
            </tr>
        }
        </tbody>
    </table>
</div>
