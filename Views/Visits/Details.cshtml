@model Visit
@{
    ViewData["Title"] = "تفاصيل الزيارة";
}

<div class="module-header">
    <div>
        <span class="module-kicker">الاستشارات الطبية</span>
        <h1>تفاصيل الزيارة</h1>
        <p>ملخص الزيارة، الطبيب، المريض، الإجراءات، والمدفوعات.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right"></i>
        رجوع
    </a>
</div>

<div class="content-card mb-3">
    <div class="details-grid">
        <div class="detail-tile"><span>التاريخ</span><strong>@Model.Date.ToString("yyyy-MM-dd")</strong></div>
        <div class="detail-tile"><span>المريض</span><strong>@Model.Patient?.Name</strong></div>
        <div class="detail-tile"><span>الطبيب</span><strong>@Model.Doctor?.Name</strong></div>
        <div class="detail-tile"><span>الدفع</span><strong>@Model.PaidAmount.ToString("N2") ج.م / @Model.TotalPrice.ToString("C")</strong></div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="notes-box">
        <strong>ملاحظات الطبيب</strong>
        <p class="mb-0">@Model.Notes</p>
        </div>
    }
</div>
<div class="content-card mb-3">
    <div class="section-head">
        <h2>التفاصيل المالية</h2>
    </div>
    <div class="details-grid">
        <div class="detail-tile">
            <span>قيمة الكشف</span>
            <strong>@Model.ExaminationPrice.ToString("N2")ج.م </strong>
        </div>
        <div class="detail-tile">
            <span>إجمالي الإجراءات</span>
            <strong>@Model.ProceduresPrice.ToString("N2")ج.م </strong>
        </div>
        <div class="detail-tile">
            <span>الخصم</span>
            <strong class="text-danger">@Model.Discount.ToString("N2")ج.م </strong>
        </div>
        <div class="detail-tile">
            <span>الإجمالي النهائي</span>
            <strong class="text-primary">@Model.TotalPrice.ToString("N2")ج.م </strong>
        </div>
        <div class="detail-tile">
            <span>المبلغ المدفوع</span>
            <strong class="text-success">@Model.PaidAmount.ToString("N2")ج.م </strong>
        </div>
        <div class="detail-tile">
            <span>حالة الدفع</span>
            <span class="status-badge @(Model.Paid ? "confirmed" : "waiting") mt-2">
                @(Model.Paid ? "مدفوع بالكامل" : "مستحق")
            </span>
        </div>
    </div>
</div>
<div class="content-card">
    <div class="section-head">
        <div>
            <h2>الإجراءات الطبية</h2>
            <p>الإجراءات المسجلة داخل الزيارة.</p>
        </div>
    </div>
    <table class="table admin-table mb-0">
        <thead><tr><th>الإجراء</th><th>الكمية</th><th>الإجمالي الفرعي</th></tr></thead>
        <tbody>
        @foreach (var item in Model.VisitProcedures)
        {
            <tr>
                <td>@item.Procedure?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.SubTotal.ToString("C")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
