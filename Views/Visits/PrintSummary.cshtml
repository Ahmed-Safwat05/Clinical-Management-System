@model ClinicManagementSystem.Models.Visit
@{
    Layout = "_PrintLayout";
    ViewData["Title"] = "ملخص الزيارة - " + Model.Patient?.Name;
}

@section HeaderLeft {
    <div style="text-align: left;">
        <h5 class="fw-bold text-dark mb-1">د/ @Model.Doctor?.Name</h5>
        <span class="badge bg-secondary">@Model.Doctor?.Specialty</span>
    </div>
}

<div class="info-bar">
    <div class="row g-3">
        <div class="col-6 col-md-4">
            <span class="text-muted">اسم المريض:</span> <strong class="text-dark">@Model.Patient?.Name</strong>
        </div>
        <div class="col-6 col-md-4">
            <span class="text-muted">تاريخ الزيارة:</span> <strong>@Model.Date.ToString("yyyy-MM-dd")</strong>
        </div>
        <div class="col-6 col-md-4 text-md-end">
            <span class="text-muted">رقم الزيارة:</span> <span class="badge bg-light text-dark border">#@Model.Id</span>
        </div>
    </div>
</div>

<div class="text-center mb-4">
    <h3 class="fw-bold text-dark">تقرير ملخص الزيارة الطبي والمالي</h3>
</div>

<h5 class="fw-bold mb-3 text-dark"><i class="bi bi-file-earmark-medical-fill text-primary me-1"></i> الملاحظات الطبية</h5>
<table class="print-table">
    <thead>
        <tr>
            <th style="width: 30%;">البند الطبي</th>
            <th style="width: 70%;">التفاصيل</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td class="fw-bold">ملاحظات وتقرير الطبيب</td>
            <td class="text-muted" style="white-space: pre-line;">@(string.IsNullOrWhiteSpace(Model.Notes) ? "لا توجد ملاحظات طبية مسجلة." : Model.Notes)</td>
        </tr>
    </tbody>
</table>

@if (Model.VisitProcedures != null && Model.VisitProcedures.Any(p => !p.IsDeleted))
{
    <h5 class="fw-bold mb-3 mt-4 text-dark"><i class="bi bi-activity text-primary me-1"></i>  الإجراءات والخدمات الطبية بالزيارة</h5>
    <table class="print-table">
        <thead>
            <tr>
                <th>اسم الخدمة / الإجراء</th>
                <th class="text-center" style="width: 20%;">الكمية</th>
                <th class="text-end" style="width: 25%;">السعر الكلي</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proc in Model.VisitProcedures.Where(p => !p.IsDeleted))
            {
                <tr>
                    <td class="fw-bold">@proc.Procedure?.Name</td>
                    <td class="text-center">@proc.Quantity</td>
                    <td class="text-end text-secondary">@proc.SubTotal.ToString("N2") ج.م</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.Prescriptions != null && Model.Prescriptions.Any())
{
    <h5 class="fw-bold mb-3 mt-4 text-dark"><i class="bi bi-capsule text-primary me-1"></i> الروشتة </h5>
    <table class="print-table">
        <thead>
            <tr>
                <th style="width: 35%;">اسم الدواء</th>
                <th style="width: 20%;">الجرعة</th>
                <th style="width: 25%;">التكرار</th>
                <th style="width: 20%;">المدة</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var med in Model.Prescriptions)
            {
                <tr>
                    <td class="med-name">@med.MedicationName</td>
                    <td>@med.Dosage</td>
                    <td>@med.Frequency</td>
                    <td>@med.Duration</td>
                </tr>
            }
        </tbody>
    </table>
}

<h5 class="fw-bold mb-3 mt-4 text-dark"><i class="bi bi-cash-stack text-primary me-1"></i> الحسابات والمدفوعات المالية</h5>
<div class="row g-3">
    <div class="col-6">
        <table class="table table-sm table-borderless align-middle" style="font-size: 0.95rem;">
            <tr>
                <td class="text-muted py-2">قيمة الكشف / المعاينة:</td>
                <td class="text-end fw-bold">@Model.ExaminationPrice.ToString("0.##") ج.م</td>
            </tr>
            <tr>
                <td class="text-muted py-2">إجمالي قيمة الإجراءات:</td>
                <td class="text-end fw-bold">@Model.ProceduresPrice.ToString("0.##") ج.م</td>
            </tr>
            @if (Model.Discount > 0)
            {
                <tr>
                    <td class="text-danger py-2">خصم ممنوح:</td>
                    <td class="text-end fw-bold text-danger">- @Model.Discount.ToString("0.##") ج.م</td>
                </tr>
            }
        </table>
    </div>

    <div class="col-6">
        <div class="p-3 border rounded bg-light">
            <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                <span class="fw-bold text-secondary">المبلغ الإجمالي الكلي:</span>
                <span class="fw-bold fs-5">@Model.TotalPrice.ToString("0.##") ج.م</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-success fw-bold">المبلغ المدفوع (الخزنة):</span>
                <span class="text-success fw-bold fs-5">@Model.TotalPaid.ToString("0.##") ج.م</span>
            </div>
            <div class="d-flex justify-content-between pt-2 border-top">
                @if (Model.IsPaidInFull)
                {
                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> مدفوعة بالكامل</span>
                    <span class="badge bg-success-subtle text-success border border-success px-2 py-1">@Model.TotalPaid.ToString("0.##") ج.م</span>
                }
                else
                {
                    <span class="text-warning fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> المتبقي مديونية:</span>
                    <span class="text-danger fw-bold fs-5">@Model.RemainingBalance.ToString("0.##") ج.م</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-7"></div>
    <div class="col-5 text-center">
        <p class="mb-4 text-muted" style="font-size: 0.9rem;">توقيع الطبيب المعالج للزيارة</p>
        <p class="fw-bold text-dark m-0">د/ @Model.Doctor?.Name</p>
        <p class="text-muted">........................................</p>
    </div>
</div>