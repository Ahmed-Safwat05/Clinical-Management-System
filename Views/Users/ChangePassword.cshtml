@model ChangePasswordViewModel
@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="module-header">
    <div>
        <span class="module-kicker">الحساب</span>
        <h1>تغيير كلمة المرور</h1>
        <p>@Model.DisplayName</p>
    </div>
</div>

<div class="content-card form-card" style="max-width: 600px;">
    <form asp-action="ChangePassword" asp-route-id="@Model.UserId" method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="DisplayName" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        @if (Model.UserId == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
        {
            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label">كلمة المرور الحالية</label>
                <input asp-for="CurrentPassword" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>
        }

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">كلمة المرور الجديدة</label>
            <input asp-for="NewPassword" class="form-control" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
            <small class="text-muted">يجب أن تكون كلمة المرور 6 أحرف على الأقل</small>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmNewPassword" class="form-label">تأكيد كلمة المرور الجديدة</label>
            <input asp-for="ConfirmNewPassword" class="form-control" />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2-circle"></i>
                حفظ كلمة المرور الجديدة
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
