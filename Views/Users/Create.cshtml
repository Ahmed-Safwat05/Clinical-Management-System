@model CreateUserViewModel
@{
    ViewData["Title"] = "إضافة مستخدم جديد";
}

<div class="module-header">
    <div>
        <span class="module-kicker">إدارة النظام</span>
        <h1>إضافة مستخدم جديد</h1>
        <p>إنشاء حساب جديد لموظف من موظفي العيادة.</p>
    </div>
</div>

<div class="content-card form-card" style="max-width: 600px;">
    <form asp-action="Create" method="post">
        
        <div asp-validation-summary="All" class="alert alert-danger custom-validation-summary"></div>

        <div class="mb-3">
            <label asp-for="Username" class="form-label">اسم المستخدم</label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DisplayName" class="form-label">الاسم الكامل</label>
            <input asp-for="DisplayName" class="form-control" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">كلمة المرور</label>
            <input asp-for="Password" class="form-control" type="password" /> <span asp-validation-for="Password" class="text-danger"></span>
            <small class="text-secondary" style="font-size: 11px;">يجب أن تكون كلمة المرور 6 أحرف على الأقل</small>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
            <input asp-for="ConfirmPassword" class="form-control" type="password" /> <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label">صلاحية المستخدم (الرول)</label>
            <select asp-for="Role" class="form-control form-select"
                    asp-items="Html.GetEnumSelectList<ClinicManagementSystem.Models.UserRole>()">
                <option value="">-- اختر صلاحية الحساب --</option>
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2-circle"></i>
                إضافة المستخدم
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i>
                إلغاء
            </a>
        </div>
    </form>
</div>

<style>
    .custom-validation-summary.validation-summary-valid {
        display: none !important;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}