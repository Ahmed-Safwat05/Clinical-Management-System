@inject ISettingsService SettingsService
@inject IProductService ProductService
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    string IsActive(string name) => string.Equals(controller, name, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    string clinicName = "عيادة الخير";
    try
    {
        clinicName = await SettingsService.GetValue(SettingKeys.ClinicName) ?? "عيادة الخير";
    }
    catch
    {
        clinicName = "عيادة الخير";
    }

    int lowStockCount = 0;
    try
    {
        lowStockCount = await ProductService.GetLowStockCountAsync();
    }
    catch
    {
        lowStockCount = 0;
    }
}
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة العيادة</title>
    <script type="importmap"></script>
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClinicManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated != true)
    {
        <main class="auth-page" role="main">
            @RenderBody()
        </main>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>

        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

        <script src="~/lib/chartjs/chart.umd.min.js"></script>

        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
        return;
    }

    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <div class="brand-mark">
                    <i class="bi bi-hospital"></i>
                </div>
                <div>
                    <span>@clinicName</span>
                    <small>المركز الطبي</small>
                </div>
            </div>

            <nav class="sidebar-menu" aria-label="القائمة الرئيسية">
                <a class="sidebar-link @IsActive("Home")" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>الرئيسية</span>
                </a>
                <a class="sidebar-link @IsActive("Patients")" asp-controller="Patients" asp-action="Index">
                    <i class="bi bi-people-fill"></i>
                    <span>المرضى</span>
                </a>
                <a class="sidebar-link @IsActive("Doctors")" asp-controller="Doctors" asp-action="Index">
                    <i class="bi bi-person-badge-fill"></i>
                    <span>الأطباء</span>
                </a>
                <a class="sidebar-link @IsActive("Appointments")" asp-controller="Appointments" asp-action="Index">
                    <i class="bi bi-calendar2-check-fill"></i>
                    <span>المواعيد</span>
                </a>
                <a class="sidebar-link @IsActive("Visits")" asp-controller="Visits" asp-action="Index">
                    <i class="bi bi-clipboard2-pulse-fill"></i>
                    <span>الزيارات</span>
                </a>
                <a class="sidebar-link @IsActive("Procedures")" asp-controller="Procedures" asp-action="Index">
                    <i class="bi bi-capsule-pill"></i>
                    <span>الإجراءات</span>
                </a>
                <a class="sidebar-link @IsActive("Products")" asp-controller="Products" asp-action="Index">
                    <i class="bi bi-box-seam"></i>
                    <span>المخزون</span>
                    @if (lowStockCount > 0)
                    {
                        <span class="badge bg-warning-subtle text-warning" style="margin-right: auto;">@lowStockCount</span>
                    }
                </a>
                <a class="sidebar-link @IsActive("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-bar-chart-line-fill"></i>
                    <span>التقارير</span>
                </a>
                <a class="sidebar-link @IsActive("Deleted")" asp-controller="Deleted" asp-action="Index">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    <span>المحذوفات</span>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <hr class="sidebar-divider my-2" />
                    <div class="sidebar-group-title">إدارة النظام</div>
                    <a class="sidebar-link @IsActive("Users")" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people-fill"></i>
                        <span>المستخدمين</span>
                    </a>
                    <a class="sidebar-link @IsActive("Settings")" asp-controller="Settings" asp-action="Index">
                        <i class="bi bi-gear-fill"></i>
                        <span>الإعدادات</span>
                    </a>
                }
            </nav>

            <form asp-controller="Account" asp-action="Logout" method="post" class="sidebar-logout">
                <button type="submit" class="sidebar-link logout-link">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>تسجيل الخروج</span>
                </button>
            </form>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <form class="topbar-search" role="search">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="search" placeholder="ابحث عن مريض، موعد..." aria-label="بحث" />
                </form>

                <div class="topbar-actions">
                    @*<div class="notification-container">
                        <button class="notification-btn" id="notificationBtn" type="button" aria-label="الإشعارات">
                            <i class="bi bi-bell-fill"></i>
                            <span class="notification-badge"></span>
                        </button>

                        <div class="notification-dropdown" id="notificationDropdown">
                            <div class="dropdown-header">الإشعارات الجديدة</div>
                            <div class="dropdown-body">
                                <a href="#" class="notification-item-link">
                                    <div class="notification-item">
                                        <i class="bi bi-calendar-event"></i>
                                        <div>
                                            <strong>موعد جديد</strong>
                                            <span>المريض أحمد طلب حجزاً</span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>*@

                        <div class="dropdown">
                            <div class="user-profile " id="userDropdown" style="cursor: pointer;">
                                <img src="~/images/receptionist-icon-svg-download-png-6973939.png" alt="صورة المستخدم" />
                                <div class="user-info">
                                    <strong>@(User.Identity?.Name ?? "مستخدم")</strong>
                                    <span>@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "موظف")</span>
                                </div>
                            </div>

                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" aria-labelledby="userDropdown" style="border-radius: 12px; min-width: 200px;">
                                @{
                                    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
                                }
                                <li>
                                    <a asp-controller="Users" asp-action="ChangePassword" asp-route-id="@userId" class="dropdown-item rounded-2 py-2 d-flex align-items-center gap-2">
                                        <i class="bi bi-key text-muted"></i>
                                        <span>تغيير كلمة المرور</span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        <button type="submit" class="dropdown-item rounded-2 py-2 text-danger d-flex align-items-center gap-2">
                                            <i class="bi bi-box-arrow-left"></i>
                                            <span>تسجيل الخروج</span>
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>

            <main class="app-content" role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/Chart.js/chart.umd.js"></script>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
